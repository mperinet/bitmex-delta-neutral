# Copy to config/.env and fill in your keys
# Testnet keys: https://testnet.bitmex.com/app/apiKeys
BITMEX_API_KEY=
BITMEX_API_SECRET=

# Readonly API key pair for the funding analysis dashboard (port 8502)
# Create a separate readonly key at https://testnet.bitmex.com/app/apiKeys
BITMEX_READONLY_API_KEY=
BITMEX_READONLY_API_SECRET=

# Binance readonly API keys for the funding analysis dashboard (port 8503).
# Required for: historical USD margin borrow rates, user borrow/interest history.
# Scope: Enable READ on Spot/Margin (no trading, no withdrawals).
BINANCE_READONLY_API_KEY=
BINANCE_READONLY_API_SECRET=

# Telegram (optional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
